RUN ROM
BITS == 32
MINHEAP 64
MINREG 26
MINSTACK 16
@DEFINE FLOAT_SCALE_FACTOR_BITS 10
@DEFINE FLOAT_SCALE_FACTOR 1024
CAL .main
HLT

.main
	PSH R1
	MOV R1 SP
	SUB SP SP 2
	ADD R3 200 400
	AND R3 R3 0xffff
	BSL R3 R3 16
	BSS R3 R3 16
	LSTR R1 -1 R3
	SUB R3 R1 1
	ADD R4 R3 400
	AND R4 R4 0xffff
	BSL R4 R4 16
	BSS R4 R4 16
	LSTR R1 -2 R4
	MOV R2 0
	MOV SP R1
	POP R1
	RET

RUN ROM
BITS == 16
MINHEAP 64
MINREG 26
MINSTACK 16
CAL .main
HLT

.add
	PSH R1
	MOV R1 SP
	SUB SP SP 2
	LSTR R1 -1 R17
	LSTR R1 -2 R18
	LLOD R3 R1 -1
	LLOD R4 R1 -2
	ADD R5 R3 R4
	MOV R2 R5
	MOV SP R1
	POP R1
	RET

.main
	PSH R1
	MOV R1 SP
	SUB SP SP 3
	LSTR R1 -1 .add
	LLOD R3 R1 -1
	LSTR R1 -2 R3
	LLOD R3 R1 -2
	MOV R17 100
	MOV R18 200
	CAL R3
	LSTR R1 -3 R2
	MOV R2 0
	MOV SP R1
	POP R1
	RET

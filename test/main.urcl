RUN ROM
BITS == 32
MINHEAP 64
MINREG 26
MINSTACK 16
@DEFINE FLOAT_SCALE_FACTOR_BITS 10
@DEFINE FLOAT_SCALE_FACTOR 1024
CAL .main
HLT

.main
	PSH R1
	MOV R1 SP
	SUB SP SP 1
	LSTR R1 -1 0

.loop_cond_1
	LLOD R4 R1 -1
	SSETL R5 R4 25
	BNE .loop_start_1 R5 0
	JMP .loop_end_1

.loop_start_1
	LLOD R5 R1 -1
	ADD R6 R5 1
	AND R6 R6 0xffff
	BSL R6 R6 16
	BSS R6 R6 16
	LSTR R1 -1 R6
	JMP .loop_cond_1

.loop_end_1
	MOV R2 0
	MOV SP R1
	POP R1
	RET

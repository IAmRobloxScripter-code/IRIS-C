RUN ROM
BITS == 32
MINHEAP 640
MINREG 26
MINSTACK 16
@DEFINE FLOAT_SCALE_FACTOR_BITS 10
@DEFINE FLOAT_SCALE_FACTOR 1024
CAL .main
HLT

.add
	PSH R1
	MOV R1 SP
	SUB SP SP 4
	LSTR R1 -1 R17
	LSTR R1 -2 R18
	LLOD R3 R1 -1
	LSTR R1 -3 R3
	LLOD R3 R1 -2
	LSTR R1 -4 R3
	SUB R3 R1 3
	LOD R4 R3
	SUB R3 R1 4
	LOD R5 R3
	ADD R3 R4 R5
	AND R3 R3 0xffff
	BSL R3 R3 16
	BSS R3 R3 16
	MOV R2 R3
	MOV SP R1
	POP R1
	RET

.main
	PSH R1
	MOV R1 SP
	SUB SP SP 1
	LSTR R1 -1 100
	LSTR R1 -2 200
	LLOD R4 R1 -1
	LSTR R1 -3 R4
	LLOD R4 R1 -2
	LSTR R1 -4 R4
	SUB R4 R1 3
	LOD R5 R4
	SUB R4 R1 4
	LOD R6 R4
	ADD R4 R5 R6
	AND R4 R4 0xffff
	BSL R4 R4 16
	BSS R4 R4 16
	MOV R2 R4
	LSTR R1 -1 R2
	MOV R2 0
	MOV SP R1
	POP R1
	RET
